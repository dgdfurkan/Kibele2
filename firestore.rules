rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Kullanıcı profilleri
    match /users/{userId} {
      allow read: if true; 
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }
    
    // Oda katılım talepleri
    match /room_requests/{reqId} {
      allow create: if isAuthenticated();
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.uid || 
        request.auth.uid == resource.data.roomOwnerId ||
        isAdmin()
      );
      allow update: if isAuthenticated() && (
        request.auth.uid == resource.data.roomOwnerId ||
        isAdmin()
      );
    }
    
    // İlham Odaları
    match /rooms/{roomId} {
      allow read: if true;
      allow write: if isAuthenticated();
      allow delete: if isAdmin();
    }
    
    // Bildirimler
    match /notifications/{notifId} {
      allow create: if isAuthenticated();
      allow read, update: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow delete: if isAdmin();
    }

    // Oda İçerikleri (Notlar, Resimler vb.)
    match /room_items/{itemId} {
      // SADECE paylaşılan panoyu, kendi panosunu veya admin ise her şeyi görebilir
      allow read: if isAuthenticated() && (
        resource.data.boardType == 'shared' || 
        resource.data.userId == request.auth.uid || 
        isAdmin()
      );
      // Yazma yetkisi giriş yapmış herkese (kendi ID'siyle oluşturması şartıyla)
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      // Sadece kendi ögesini veya admin silebilir/güncelleyebilir
      allow update, delete: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || 
        isAdmin()
      );
    }
  }
}
