rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Kullanıcı profilleri
    match /users/{userId} {
      allow read: if true; 
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }
    
    // Kibele AI Sohbet Geçmişi
    match /users/{userId}/kibele_chats/{roomId}/messages/{messageId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // Admin Projeleri
    match /users/{userId}/projects/{projectId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
    }
    
    // Oda katılım talepleri
    match /room_requests/{reqId} {
      allow create: if isAuthenticated();
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.uid || 
        request.auth.uid == resource.data.roomOwnerId ||
        isAdmin()
      );
      allow update: if isAuthenticated() && (
        request.auth.uid == resource.data.roomOwnerId ||
        isAdmin()
      );
    }
    
    // İlham Odaları
    match /rooms/{roomId} {
      allow read: if true;
      allow create: if isAuthenticated();
      // Kurucu veya Admin her şeyi güncelleyebilir. 
      // Herkese açık odalarda (isPrivate: false) herkes katılımcı listesine kendisini ekleyebilir.
      allow update: if isAuthenticated() && (
        resource.data.creatorId == request.auth.uid || 
        isAdmin() || 
        (resource.data.isPrivate == false && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['participants']))
      );
      allow delete: if isAdmin();
    }
    
    // Bildirimler
    match /notifications/{notifId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    // Gizlilik Ayarları (isPublic)
    match /room_privacy/{privacyId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (
        request.auth.uid == userIdFromPrivacyId(privacyId) || 
        isAdmin()
      );
    }
    
    function userIdFromPrivacyId(privacyId) {
      // privacyId formatı: {roomId}_{userId}
      return privacyId.split('_')[1];
    }

    // Oda İçerikleri (Notlar, Resimler vb.)
    match /room_items/{itemId} {
      // SADECE paylaşılan panoyu, kendi panosunu, admin ise her şeyi 
      // VEYA panosu "Public" olan başka bir öğrenciyi görebilir.
      allow read: if isAuthenticated() && (
        resource.data.boardType == 'shared' || 
        resource.data.userId == request.auth.uid || 
        isAdmin() ||
        get(/databases/$(database)/documents/room_privacy/$(resource.data.roomId + '_' + resource.data.userId)).data.isPublic == true
      );
      // Yazma yetkisi (Kendi panosu VEYA Admin ise her panyou editleyebilir)
      allow create: if isAuthenticated() && (
        request.resource.data.userId == request.auth.uid || 
        isAdmin()
      );
      // Silme/Güncelleme
      allow update, delete: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || 
        isAdmin()
      );
    }

    function getBaseRoomId(fullId) {
      // room_id_shared veya room_id_userId formatından asıl room_id'yi çıkar
      return fullId.split('_')[0];
    }

    // tldraw Şekilleri (Yeni Tek Doküman Modeli)
    match /rooms/{roomId}/canvas/{docId} {
      allow read: if isAuthenticated() && (
        get(/databases/$(database)/documents/rooms/$(getBaseRoomId(roomId))).data.isPrivate == false ||
        get(/databases/$(database)/documents/rooms/$(getBaseRoomId(roomId))).data.participants.hasAny([request.auth.uid]) ||
        get(/databases/$(database)/documents/rooms/$(getBaseRoomId(roomId))).data.creatorId == request.auth.uid ||
        isAdmin()
      );
      allow write: if isAuthenticated() && (
        get(/databases/$(database)/documents/rooms/$(getBaseRoomId(roomId))).data.participants.hasAny([request.auth.uid]) ||
        get(/databases/$(database)/documents/rooms/$(getBaseRoomId(roomId))).data.creatorId == request.auth.uid ||
        isAdmin()
      );
    }

    // Eski tldraw Şekilleri (Geriye dönük uyumluluk için şimdilik kalsın)
    match /rooms/{roomId}/shapes/{shapeId} {
      allow read: if isAuthenticated() && (
        get(/databases/$(database)/documents/rooms/$(getBaseRoomId(roomId))).data.participants.hasAny([request.auth.uid]) ||
        get(/databases/$(database)/documents/rooms/$(getBaseRoomId(roomId))).data.creatorId == request.auth.uid ||
        isAdmin()
      );
      allow create, update: if isAuthenticated() && (
        get(/databases/$(database)/documents/rooms/$(getBaseRoomId(roomId))).data.participants.hasAny([request.auth.uid]) ||
        get(/databases/$(database)/documents/rooms/$(getBaseRoomId(roomId))).data.creatorId == request.auth.uid ||
        isAdmin()
      );
      allow delete: if isAdmin() || (
        isAuthenticated() && 
        get(/databases/$(database)/documents/rooms/$(getBaseRoomId(roomId))).data.creatorId == request.auth.uid
      );
    }

    // Oda Aktiviteleri (Loglar)
    match /rooms/{roomId}/activity/{activityId} {
      allow read, create: if isAuthenticated() && (
        get(/databases/$(database)/documents/rooms/$(getBaseRoomId(roomId))).data.participants.hasAny([request.auth.uid]) ||
        get(/databases/$(database)/documents/rooms/$(getBaseRoomId(roomId))).data.creatorId == request.auth.uid ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // Oda Kürasyonları (Kaydedilenler)
    match /rooms/{roomId}/curations/{curationId} {
      allow read, create: if isAuthenticated() && (
        get(/databases/$(database)/documents/rooms/$(roomId)).data.participants.hasAny([request.auth.uid]) ||
        get(/databases/$(database)/documents/rooms/$(roomId)).data.creatorId == request.auth.uid ||
        isAdmin()
      );
      allow delete: if isAdmin() || (
        isAuthenticated() && 
        get(/databases/$(database)/documents/rooms/$(roomId)).data.creatorId == request.auth.uid
      );
    }
  }
}
