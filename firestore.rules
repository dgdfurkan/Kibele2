rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Kullanıcı profilleri
    match /users/{userId} {
      allow read: if true; 
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Oda katılım talepleri (Yeni)
    match /room_requests/{reqId} {
      // Herkes istek oluşturabilir
      allow create: if request.auth != null;
      
      // Kullanıcı kendi isteğini, admin ise her şeyi görebilir
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.uid || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
      
      // Sadece admin onaylayabilir veya reddedebilir
      allow update: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // İlham Odaları
    match /rooms/{roomId} {
      allow read: if true;
      // Adminler veya Auth olan kullanıcılar yazabilir (participants listesi için)
      allow write: if request.auth != null;
    }
    
    // Eski erişim talepleri (Geriye dönük uyumluluk)
    match /access_requests/{reqId} {
      allow read: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      allow create: if true;
    }
  }
}
