rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Kullanıcı profilleri
    match /users/{userId} {
      allow read: if true; 
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Oda katılım talepleri (Yeni)
    match /room_requests/{reqId} {
      // Herkes istek oluşturabilir
      allow create: if request.auth != null;
      
      // Kullanıcı kendi isteğini, admin ise her şeyi görebilir
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.uid || 
        request.auth.uid == resource.data.roomOwnerId ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
      
      // Admin veya oda sahibi onaylayabilir/reddedebilir
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.roomOwnerId ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }
    
    // İlham Odaları
    match /rooms/{roomId} {
      allow read: if true;
      // Adminler veya Auth olan kullanıcılar yazabilir (participants listesi için)
      allow write: if request.auth != null;
    }
    
    // Eski erişim talepleri (Geriye dönük uyumluluk)
    match /access_requests/{reqId} {
      allow read: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      allow create: if true;
    }

    // Bildirimler (Yeni)
    match /notifications/{notifId} {
      // Herkes (sistem/kullanıcı) bildirim oluşturabilir
      allow create: if request.auth != null;
      // Sadece bildirimin sahibi okuyabilir ve okundu olarak güncelleyebilir
      allow read, update: if request.auth != null && request.auth.uid == resource.data.userId;
      // Silme yetkisi şimdilik kapalı veya sadece admin
      allow delete: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Oda İçerikleri (Notlar, Resimler vb.)
    match /room_items/{itemId} {
      // Okuma herkese açık (Oda bazlı kısıtlama ileride eklenebilir)
      allow read: if true;
      // Yazma yetkisi giriş yapmış herkese
      allow create: if request.auth != null;
      // Sadece kendi ögesini veya admin silebilir
      allow delete: if request.auth != null && (
        request.auth.uid == resource.data.userId || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
      // Güncelleme şimdilik kapalı veya sadece sahibi
      allow update: if request.auth != null && request.auth.uid == resource.data.userId;
    }
  }
}
